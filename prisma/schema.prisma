// Fermo — Plataforma (Fábrica de calçados sob encomenda)
// Schema núcleo (Fases 0–1). Multi-tenant single-database.
// PostgreSQL (Neon em produção). Toda entidade de negócio tem tenantId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────
// Tenancy & organização
// ──────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies        Company[]
  users            User[]
  customers        Customer[]
  leads            Lead[]
  opportunities    Opportunity[]
  products         Product[]
  sizeGrids        SizeGrid[]
  materials        Material[]
  productVariants  ProductVariant[]
  techSheets       TechSheet[]
  techSheetVersions TechSheetVersion[]
  bomItems         BomItem[]
  configRequests   ConfigRequest[]
  quotes           Quote[]
  salesOrders      SalesOrder[]
  productionOrders ProductionOrder[]
  productionSteps  ProductionStep[]
  productionEvents ProductionEvent[]
  qualityInspections QualityInspection[]
  qualityDefects   QualityDefect[]
  suppliers        Supplier[]
  stockBalances    StockBalance[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  financialEntries FinancialEntry[]
  invoices         Invoice[]
  shipments        Shipment[]
  files            File[]
  notifications    Notification[]
}

model Company {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  cnpj      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// Identidade, RBAC
// Role e Permission são globais (catálogo). User pertence a um tenant.
// ──────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  key         String   @unique // ex: "admin", "comercial", "producao", "cliente"
  name        String
  description String?
  createdAt   DateTime @default(now())

  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // ex: "quote:approve"
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  roleId       String
  // Para usuários do portal do cliente: vínculo opcional com Customer
  customerId   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role     Role      @relation(fields: [roleId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// Auditoria
// ──────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String // CREATE | UPDATE | DELETE
  model     String
  recordId  String?
  before    Json?
  after     Json?
  source    String? // ex: "server-action", "api", "seed"
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, model])
}

// ──────────────────────────────────────────────────────────────
// CRM — clientes / leads / oportunidades
// ──────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // marca / razão social
  cnpj      String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts    CustomerContact[]
  addresses   Address[]
  leads       Lead[]
  quotes      Quote[]
  salesOrders SalesOrder[]
  users       User[]

  @@index([tenantId])
}

model CustomerContact {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  name       String
  email      String?
  phone      String?
  role       String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
}

model Address {
  id         String  @id @default(cuid())
  tenantId   String
  customerId String
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  zip        String?
  country    String  @default("BR")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  company   String?
  email     String?
  phone     String?
  message   String?
  source    String? // ex: "site", "configurador", "indicacao"
  status    LeadStatus @default(NEW)
  // vínculo após qualificação/conversão
  customerId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer?      @relation(fields: [customerId], references: [id])
  opportunities Opportunity[]
  configRequest ConfigRequest?

  @@index([tenantId])
  @@index([tenantId, status])
}

enum OpportunityStage {
  NEW
  QUALIFICATION
  QUOTING
  NEGOTIATION
  WON
  LOST
}

model Opportunity {
  id        String           @id @default(cuid())
  tenantId  String
  title     String
  leadId    String?
  stage     OpportunityStage @default(NEW)
  value     Decimal?         @db.Decimal(12, 2)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead?   @relation(fields: [leadId], references: [id])
  quotes Quote[]

  @@index([tenantId])
  @@index([tenantId, stage])
}

// ──────────────────────────────────────────────────────────────
// Catálogo básico / grade / configurador
// ──────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  basePrice   Decimal  @default(0) @db.Decimal(12, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sizeGridId String?
  sizeGrid   SizeGrid?       @relation(fields: [sizeGridId], references: [id])
  quoteItems QuoteItem[]
  orderItems SalesOrderItem[]

  // PLM (Fase 2)
  variants   ProductVariant[]
  techSheets TechSheet[]
  bomItems   BomItem[]        @relation("ProductBom")          // itens da BOM deste produto
  usedInBom  BomItem[]        @relation("ProductBomComponent") // onde este produto é subcomponente

  @@unique([tenantId, sku])
  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// PLM — materiais, variantes, ficha técnica versionada, BOM multinível
// ──────────────────────────────────────────────────────────────

model Material {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  category    String? // ex: "couro", "solado", "forro", "aviamento"
  unit        String   @default("un") // un, par, m2, kg, m
  costPerUnit Decimal  @default(0) @db.Decimal(12, 4)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bomItems           BomItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProductVariant {
  id         String   @id @default(cuid())
  tenantId   String
  productId  String
  sku        String
  name       String // ex: "Preto / Couro liso"
  color      String?
  attributes Json? // { couro: "liso", cor: "preto", solado: "borracha" }
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([productId])
}

model TechSheet {
  id             String   @id @default(cuid())
  tenantId       String
  productId      String
  currentVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  versions TechSheetVersion[]

  @@unique([tenantId, productId])
  @@index([tenantId])
}

model TechSheetVersion {
  id          String   @id @default(cuid())
  tenantId    String
  techSheetId String
  version     Int
  title       String?
  // ficha técnica: especificações, roteiro de etapas, consumo, observações
  content     Json
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  techSheet TechSheet @relation(fields: [techSheetId], references: [id], onDelete: Cascade)

  @@unique([techSheetId, version])
  @@index([tenantId])
}

enum BomComponentType {
  MATERIAL
  PRODUCT
}

model BomItem {
  id        String           @id @default(cuid())
  tenantId  String
  productId String // produto/montagem dono desta linha de BOM
  type      BomComponentType
  // exatamente um dos dois é preenchido conforme `type`
  componentMaterialId String?
  componentProductId  String?
  quantity  Decimal          @default(1) @db.Decimal(12, 4)
  unit      String           @default("un")
  note      String?
  createdAt DateTime         @default(now())

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product   @relation("ProductBom", fields: [productId], references: [id], onDelete: Cascade)
  componentMaterial Material? @relation(fields: [componentMaterialId], references: [id])
  componentProduct  Product?  @relation("ProductBomComponent", fields: [componentProductId], references: [id])

  @@index([tenantId])
  @@index([productId])
}

model SizeGrid {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // ex: "Feminino 33-40"
  sizes     Int[] // ex: [33,34,35,...]
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([tenantId])
}

model ConfigRequest {
  id        String   @id @default(cuid())
  tenantId  String
  leadId    String?  @unique
  // payload do configurador passo a passo (modelo, couro, cor, solado, grade...)
  payload   Json
  summary   String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id])

  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// Orçamento (Quote) com versões
// ──────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

model Quote {
  id            String      @id @default(cuid())
  tenantId      String
  number        String // ex: "ORC-2026-0001"
  customerId    String
  opportunityId String?
  status        QuoteStatus @default(DRAFT)
  // token público para o portal do cliente aprovar/recusar
  publicToken   String      @unique @default(cuid())
  currentVersion Int        @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer       @relation(fields: [customerId], references: [id])
  opportunity Opportunity?   @relation(fields: [opportunityId], references: [id])
  versions    QuoteVersion[]
  items       QuoteItem[]
  salesOrder  SalesOrder?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
}

model QuoteVersion {
  id         String      @id @default(cuid())
  tenantId   String
  quoteId    String
  version    Int
  status     QuoteStatus @default(DRAFT)
  subtotal   Decimal     @db.Decimal(12, 2)
  discount   Decimal     @default(0) @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  notes      String?
  // snapshot dos itens nesta versão
  snapshot   Json
  // decisão do cliente
  decidedAt  DateTime?
  decidedBy  String?
  createdAt  DateTime    @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, version])
  @@index([tenantId])
}

model QuoteItem {
  id          String  @id @default(cuid())
  tenantId    String
  quoteId     String
  productId   String?
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([quoteId])
}

// ──────────────────────────────────────────────────────────────
// Pedido (SalesOrder) e Ordem de produção (ProductionOrder)
// ──────────────────────────────────────────────────────────────

enum SalesOrderStatus {
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  CANCELLED
}

model SalesOrder {
  id         String           @id @default(cuid())
  tenantId   String
  number     String // ex: "PED-2026-0001"
  customerId String
  quoteId    String?          @unique
  status     SalesOrderStatus @default(CONFIRMED)
  total      Decimal          @db.Decimal(12, 2)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id])
  quote           Quote?           @relation(fields: [quoteId], references: [id])
  items           SalesOrderItem[]
  productionOrders ProductionOrder[]
  invoices        Invoice[]
  shipments       Shipment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
}

model SalesOrderItem {
  id          String  @id @default(cuid())
  tenantId    String
  orderId     String
  productId   String?
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([orderId])
}

enum ProductionOrderStatus {
  PLANNED
  CUTTING
  STITCHING
  ASSEMBLY
  FINISHING
  DONE
}

model ProductionOrder {
  id        String                @id @default(cuid())
  tenantId  String
  number    String // ex: "OP-2026-0001"
  orderId   String
  status    ProductionOrderStatus @default(PLANNED)
  quantity  Int
  notes     String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       SalesOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  steps       ProductionStep[]
  events      ProductionEvent[]
  inspections QualityInspection[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
}

// ──────────────────────────────────────────────────────────────
// MES / chão de fábrica (Fase 3) — roteiro, apontamento, qualidade
// ──────────────────────────────────────────────────────────────

enum ProductionStepStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model ProductionStep {
  id                String               @id @default(cuid())
  tenantId          String
  productionOrderId String
  sequence          Int
  sector            String // Corte, Pesponto, Montagem, Acabamento, Expedição
  status            ProductionStepStatus @default(PENDING)
  qtyTarget         Int
  qtyDone           Int                  @default(0)
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionOrder ProductionOrder   @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  events          ProductionEvent[]
  inspections     QualityInspection[]

  @@unique([productionOrderId, sequence])
  @@index([tenantId])
  @@index([productionOrderId])
}

enum ProductionEventType {
  START
  PRODUCE
  PAUSE
  COMPLETE
}

model ProductionEvent {
  id                String              @id @default(cuid())
  tenantId          String
  productionOrderId String
  stepId            String?
  type              ProductionEventType
  quantity          Int                 @default(0)
  operator          String?
  note              String?
  // origem do apontamento: "qr", "admin"
  source            String?
  createdAt         DateTime            @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  step            ProductionStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([productionOrderId])
}

enum QualityResult {
  PASS
  PARTIAL
  FAIL
}

model QualityInspection {
  id                String        @id @default(cuid())
  tenantId          String
  productionOrderId String
  stepId            String?
  inspector         String?
  result            QualityResult
  sampleSize        Int           @default(0)
  approvedQty       Int           @default(0)
  rejectedQty       Int           @default(0)
  notes             String?
  createdAt         DateTime      @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  step            ProductionStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  defects         QualityDefect[]

  @@index([tenantId])
  @@index([productionOrderId])
}

enum DefectSeverity {
  LOW
  MEDIUM
  HIGH
}

model QualityDefect {
  id           String         @id @default(cuid())
  tenantId     String
  inspectionId String
  type         String
  quantity     Int            @default(1)
  severity     DefectSeverity @default(LOW)

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspection QualityInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([inspectionId])
}

// ──────────────────────────────────────────────────────────────
// Suprimentos (Fase 4) — fornecedores, estoque, compras, MRP, facção
// ──────────────────────────────────────────────────────────────

enum SupplierKind {
  MATERIAL
  FACCAO
}

model Supplier {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  cnpj      String?
  email     String?
  phone     String?
  kind      SupplierKind @default(MATERIAL)
  notes     String?
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

enum StockRefType {
  MATERIAL
  PRODUCT
}

model StockBalance {
  id        String       @id @default(cuid())
  tenantId  String
  refType   StockRefType
  refId     String
  quantity  Decimal      @default(0) @db.Decimal(14, 4)
  reserved  Decimal      @default(0) @db.Decimal(14, 4)
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, refType, refId])
  @@index([tenantId])
}

enum StockMovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUST
}

model StockMovement {
  id        String            @id @default(cuid())
  tenantId  String
  refType   StockRefType
  refId     String
  type      StockMovementType
  quantity  Decimal           @db.Decimal(14, 4)
  note      String?
  refDoc    String? // ex.: número da PO ou OP
  createdAt DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, refType, refId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  number      String // ex.: "PC-2026-0001"
  supplierId  String
  status      PurchaseOrderStatus @default(DRAFT)
  total       Decimal             @default(0) @db.Decimal(14, 2)
  publicToken String              @unique @default(cuid()) // portal da facção
  notes       String?
  expectedAt  DateTime?
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  tenantId        String
  purchaseOrderId String
  materialId      String?
  description     String
  quantity        Decimal @db.Decimal(14, 4)
  unitCost        Decimal @db.Decimal(14, 4)
  lineTotal       Decimal @db.Decimal(14, 2)

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material      Material?     @relation(fields: [materialId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
}

// ──────────────────────────────────────────────────────────────
// Financeiro & Logística (Fase 5)
// ──────────────────────────────────────────────────────────────

enum FinancialType {
  RECEIVABLE
  PAYABLE
}

enum FinancialKind {
  SALE
  PURCHASE
  COMMISSION
  OTHER
}

enum FinancialStatus {
  OPEN
  PAID
  CANCELLED
}

model FinancialEntry {
  id          String          @id @default(cuid())
  tenantId    String
  type        FinancialType
  kind        FinancialKind   @default(OTHER)
  status      FinancialStatus @default(OPEN)
  description String
  amount      Decimal         @db.Decimal(14, 2)
  dueDate     DateTime
  paidDate    DateTime?
  // referências (escalares; sem FK para reduzir acoplamento)
  customerId      String?
  supplierId      String?
  salesOrderId    String?
  purchaseOrderId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type, status])
}

enum InvoiceStatus {
  ISSUED
  CANCELLED
}

model Invoice {
  id           String        @id @default(cuid())
  tenantId     String
  number       String // ex.: "NF-2026-0001"
  salesOrderId String
  status       InvoiceStatus @default(ISSUED)
  total        Decimal       @db.Decimal(14, 2)
  issuedAt     DateTime      @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
}

model Shipment {
  id           String         @id @default(cuid())
  tenantId     String
  salesOrderId String
  status       ShipmentStatus @default(PENDING)
  carrier      String?
  trackingCode String?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// Arquivos & notificações
// ──────────────────────────────────────────────────────────────

model File {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  url       String
  mimeType  String?
  size      Int?
  // referência genérica
  refModel  String?
  refId     String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  title     String
  body      String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId])
}
