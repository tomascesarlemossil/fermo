# ──────────────────────────────────────────────────────────────
# Banco — PostgreSQL (Neon em produção)
# DATABASE_URL: use a connection string POOLED (pgbouncer) do Neon.
# DIRECT_URL:   use a connection string DIRECT do Neon (migrations).
# Para dev local com Postgres:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fermo?schema=public"
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# Auth.js — gere um segredo com: openssl rand -base64 32
AUTH_SECRET="troque-este-segredo-em-producao"
AUTH_TRUST_HOST="true"

# Tenant padrão usado por rotas públicas (captura de lead do site)
DEFAULT_TENANT_SLUG="fermo"
