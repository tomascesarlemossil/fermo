# ──────────────────────────────────────────────────────────────
# Banco — PostgreSQL (Neon em produção)
# DATABASE_URL: use a connection string POOLED (pgbouncer) do Neon.
# DIRECT_URL:   use a connection string DIRECT do Neon (migrations).
# Para dev local com Postgres:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fermo?schema=public"
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# Auth.js — gere um segredo com: openssl rand -base64 32
AUTH_SECRET="troque-este-segredo-em-producao"
AUTH_TRUST_HOST="true"

# Tenant padrão usado por rotas públicas (captura de lead do site)
DEFAULT_TENANT_SLUG="fermo"

# URL pública da aplicação (links de orçamento/projeto, webhooks)
APP_PUBLIC_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────
# FERMO STUDIO — integrações (todas opcionais; modo sandbox por padrão).
# Não inserir segredos reais no repositório. Ver docs/fermo-studio/.
# ──────────────────────────────────────────────────────────────
# Armazenamento de arquivos (GLB de modelos, logos de marca). Vazio = /public (dev).
STORAGE_PROVIDER=""        # s3 | cloudinary | (vazio)
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Pagamentos (sinal/saldo). sandbox = simulação para demonstração.
PAYMENT_PROVIDER="sandbox" # sandbox | asaas | mercadopago | stripe
PAYMENT_API_KEY=""
PAYMENT_WEBHOOK_SECRET=""

# E-mail transacional / WhatsApp (automações do Studio)
EMAIL_PROVIDER=""
EMAIL_API_KEY=""
WHATSAPP_PROVIDER=""
WHATSAPP_TOKEN=""

# IA (assistente de criação). Sem chave, usa heurística local.
AI_PROVIDER=""
AI_API_KEY=""

